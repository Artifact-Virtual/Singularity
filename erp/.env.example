# ═══════════════════════════════════════════════════════════
#  Artifact Virtual ERP — Environment Configuration
#  Copy to .env and fill in real values. DO NOT commit .env.
# ═══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (required) ─────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/artifact_erp

# ── JWT (required — app crashes without these) ──────────
JWT_SECRET=          # Generate: openssl rand -base64 48
JWT_REFRESH_SECRET=  # Generate: openssl rand -base64 48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────
# Comma-separated origins allowed
CORS_ORIGIN=http://localhost:5173

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# ── S3 Storage ──────────────────────────────────────────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Seed Credentials (for prisma db seed only) ─────────
SEED_ADMIN_PASSWORD=  # Set a strong password for admin@artifactvirtual.com
SEED_DEV_PASSWORD=    # Set a strong password for ali.shakil@live.com
