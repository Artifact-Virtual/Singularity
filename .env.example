# ============================================================
#  SINGULARITY [AE] — Environment Variables
# ============================================================
#  Copy to .env and fill in your values.
#  NEVER commit the actual .env file.
# ============================================================

# ── LLM Providers ──────────────────────────────────────────
# At least one provider is required. The system cascades through
# them in order: proxy → ollama → direct API.

# GitHub Copilot Proxy (recommended — free with GitHub Pro)
SINGULARITY_PROXY_URL=http://localhost:3000/v1
SINGULARITY_PROXY_KEY=n/a

# Ollama (local, sovereign — no API key needed)
SINGULARITY_OLLAMA_URL=http://localhost:11434
SINGULARITY_OLLAMA_MODEL=qwen2.5-coder:7b

# Direct API keys (optional, used as fallbacks)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ── Discord ────────────────────────────────────────────────
SINGULARITY_DISCORD_TOKEN=
SINGULARITY_DISCORD_GUILD_ID=
SINGULARITY_DISCORD_AUTHORIZED_USERS=

# ── WhatsApp (optional) ───────────────────────────────────
# SINGULARITY_WHATSAPP_ACCOUNT_KEY=
# SINGULARITY_WHATSAPP_GATEWAY_URL=http://localhost:18789

# ── Workspace ─────────────────────────────────────────────
SINGULARITY_WORKSPACE=/path/to/your/workspace

# ── Logging ───────────────────────────────────────────────
SINGULARITY_LOG_LEVEL=INFO

# ── COMB Memory (optional — enables persistence) ──────────
# COMB_API_URL=https://api.artifactvirtual.com
# COMB_API_KEY=comb_...

# ── POA Monitoring (optional) ─────────────────────────────
# SINGULARITY_ALERT_EMAIL=ops@yourcompany.com
# SINGULARITY_ALERT_WEBHOOK=https://hooks.slack.com/...
